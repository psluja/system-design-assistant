  "descriptions": {
    "cli_cmd": "Web/mobile issuing writes (POST commands)",
    "cli_qry": "Web/mobile issuing reads (GET queries)",
    "waf": "AWS WAF (managed) at the edge of the write API",
    "alb_w": "AWS Application Load Balancer (managed), command path",
    "apigw": "Amazon API Gateway REST (managed): auth + throttling",
    "cmd": "ECS on Fargate service, 2 tasks (maxUnits — one per AZ): validates + dedups, writes the source of truth, emits 3 events per command",
    "rds": "Amazon RDS Proxy (managed) — connection pooling for the write DB",
    "aurora": "Amazon Aurora PostgreSQL (managed, Multi-AZ writer) — source of truth, strongly consistent",
    "kafka": "Apache Kafka, self-managed on EC2 (the catalog's stream.kafka pricing identity; Amazon MSK would be the managed alternative). Ordered per-key event backbone, fan-out to projectors",
    "saga": "ECS on Fargate service, 3 tasks: consumes events, issues follow-up commands (acyclic: writes to source of truth)",
    "proj_read": "ECS on Fargate service, 3 tasks: builds the relational read model from events",
    "proj_srch": "ECS on Fargate service, 3 tasks: builds the search index from events",
    "proj_hot": "ECS on Fargate service, 2 tasks: maintains the hot cache projection from events",
    "rstore": "Amazon RDS for PostgreSQL (managed, Multi-AZ) — relational read model for queries",
    "es": "Amazon OpenSearch Service (managed, 3-AZ domain, sourced pricing) — search projection",
    "redis": "Redis OSS, self-managed on EC2 (the catalog's cache.redis pricing identity; ElastiCache would be the managed alternative). Hot read projection / query cache",
    "dlq": "Amazon SQS (managed) — dead-letter queue for failed search projection",
    "notifier": "AWS Lambda (managed serverless, pay-per-use, sourced pricing) — sends user notifications from events",
    "analytics": "ECS on Fargate service, 3 tasks: windowed aggregation of events",
    "s3_an": "Amazon S3 (managed object store) — aggregated analytics output",
    "cdn": "Amazon CloudFront (managed CDN) — edge cache/TLS for the query API",
    "alb_r": "AWS Application Load Balancer (managed), query path",
    "query": "ECS on Fargate service, 6 tasks: serves reads — cache first, read store on the 20% miss"
  },
