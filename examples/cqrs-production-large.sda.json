  "labels": {
    "cli_cmd": "Command clients",
    "cli_qry": "Query clients",
    "waf": "WAF",
    "alb_w": "ALB (write)",
    "apigw": "API Gateway",
    "cmd": "Command service",
    "rds": "RDS Proxy",
    "aurora": "Write DB (Aurora)",
    "kafka": "Event log (Kafka)",
    "saga": "Saga / process mgr",
    "proj_read": "Read-model projector",
    "proj_srch": "Search projector",
    "proj_hot": "Hot projector",
    "rstore": "Read store (RDS PG)",
    "es": "Search (OpenSearch)",
    "redis": "Hot cache (Redis)",
    "dlq": "DLQ",
    "notifier": "Notification worker",
    "analytics": "Analytics consumer",
