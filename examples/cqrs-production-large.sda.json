{
  "schema": 7,
  "id": "p1",
  "name": "CQRS production (large)",
  "instances": [
    {
      "id": "cli_cmd",
      "type": "client.web",
      "config": {
        "throughput": 500
      },
      "ranges": {
        "throughput": {
          "lo": 300,
          "hi": 700
        }
      }
    },
    {
      "id": "cli_qry",
      "type": "client.web",
      "config": {
        "throughput": 10000
      },
      "ranges": {
        "throughput": {
          "lo": 6000,
          "hi": 14000
        }
      },
      "bands": [
        {
          "key": "latency",
          "band": {
            "shape": "minTargetMax",
            "max": 80
          }
        }
      ]
    },
    {
      "id": "waf",
      "type": "security.waf",
      "bands": [
        {
          "key": "latency",
          "band": {
            "shape": "minTargetMax",
            "max": 250
          }
        }
      ]
    },
    {
      "id": "alb_w",
      "type": "lb.alb",
      "bands": [
        {
          "key": "latency",
          "band": {
            "shape": "minTargetMax",
            "max": 200
          }
        }
      ]
    },
    {
      "id": "apigw",
      "type": "apigw.rest",
      "bands": [
        {
          "key": "latency",
          "band": {
            "shape": "minTargetMax",
            "max": 200
          }
        }
      ]
    },
    {
      "id": "cmd",
      "type": "compute.fargate",
      "config": {
        "concurrency": 16,
        "perRequestDuration": 25,
        "latency": 25,
        "maxUnits": 2
      },
      "transforms": {
        "out": {
          "kind": "ratio",
          "value": 3
        }
      },
      "bands": [
        {
          "key": "latency",
          "band": {
            "shape": "minTargetMax",
            "max": 200
          }
        }
      ]
    },
    {
      "id": "rds",
      "type": "proxy.rds"
    },
    {
      "id": "aurora",
      "type": "db.aurora"
    },
    {
      "id": "kafka",
      "type": "stream.kafka",
      "config": {
        "drainRate": 3000
      }
    },
    {
      "id": "saga",
      "type": "compute.fargate",
      "config": {
        "concurrency": 16,
        "perRequestDuration": 25,
        "latency": 25,
        "maxUnits": 3
      },
      "transforms": {
        "db": {
          "kind": "prob",
          "value": 0.3
        }
      }
    },
    {
      "id": "proj_read",
      "type": "compute.fargate",
      "config": {
        "concurrency": 16,
        "perRequestDuration": 20,
        "latency": 20,
        "maxUnits": 3
      },
      "ranges": {
        "perRequestDuration": {
          "lo": 10,
          "mode": 20,
          "hi": 40
        }
      }
    },
    {
      "id": "proj_srch",
      "type": "compute.fargate",
      "config": {
        "concurrency": 16,
        "perRequestDuration": 25,
        "latency": 25,
        "maxUnits": 3
      }
    },
    {
      "id": "proj_hot",
      "type": "compute.fargate",
      "config": {
        "concurrency": 16,
        "perRequestDuration": 10,
        "latency": 10,
        "maxUnits": 2
      }
    },
    {
      "id": "rstore",
      "type": "db.postgres",
      "bands": [
        {
          "key": "cost",
          "band": {
            "shape": "minTargetMax",
            "max": 30000
          }
        }
      ],
      "config": {
        "latency": 15,
        "perRequestDuration": 15
      },
      "ranges": {
        "perRequestDuration": {
          "lo": 10,
          "mode": 15,
          "hi": 30
        }
      }
    },
    {
      "id": "es",
      "type": "search.opensearch"
    },
    {
      "id": "redis",
      "type": "cache.redis",
      "config": {
        "availability": 0.9999
      }
    },
    {
      "id": "dlq",
      "type": "queue.sqs"
    },
    {
      "id": "notifier",
      "type": "compute.lambda"
    },
    {
      "id": "analytics",
      "type": "compute.fargate",
      "config": {
        "concurrency": 16,
        "perRequestDuration": 25,
        "latency": 25,
        "maxUnits": 3
      },
      "transforms": {
        "out": {
          "kind": "window",
          "value": 1000
        }
      }
    },
    {
      "id": "s3_an",
      "type": "storage.object"
    },
    {
      "id": "cdn",
      "type": "cdn.cloudfront",
      "config": {
        "throughput": 150000
      },
      "transforms": {
        "out": {
          "kind": "ratio",
          "value": 0.7
        }
      },
      "bands": [
        {
          "key": "latency",
          "band": {
            "shape": "minTargetMax",
            "max": 120
          }
        },
        {
          "key": "tailLatency",
          "band": {
            "shape": "percentiles",
            "targets": {
              "__map": [
                [
                  "p99",
                  300
                ]
              ]
            }
          }
        },
        {
          "key": "availability",
          "band": {
            "shape": "minTargetMax",
            "min": 0.999
          }
        }
      ]
    },
    {
      "id": "alb_r",
      "type": "lb.alb"
    },
    {
      "id": "query",
      "type": "compute.fargate",
      "config": {
        "concurrency": 16,
        "perRequestDuration": 10,
        "latency": 10,
        "maxUnits": 6,
        "availability": 0.9997
      }
    }
  ],
  "wires": [
    {
      "from": [
        "cli_cmd",
        "out"
      ],
      "to": [
        "waf",
        "in"
      ],
      "semantics": "sync"
    },
    {
      "from": [
        "waf",
        "out"
      ],
      "to": [
        "alb_w",
        "in"
      ],
      "semantics": "sync"
    },
    {
      "from": [
        "alb_w",
        "out"
      ],
      "to": [
        "apigw",
        "in"
      ],
      "semantics": "sync"
    },
    {
      "from": [
        "apigw",
        "out"
      ],
      "to": [
        "cmd",
        "in"
      ],
      "semantics": "sync"
    },
    {
      "from": [
        "cmd",
        "db"
      ],
      "to": [
        "rds",
        "in"
      ],
      "semantics": "sync"
    },
    {
      "from": [
        "rds",
        "out"
      ],
      "to": [
        "aurora",
        "in"
      ],
      "semantics": "sync"
    },
    {
      "from": [
        "cmd",
        "out"
      ],
      "to": [
        "kafka",
        "in"
      ],
      "semantics": "async"
    },
    {
      "from": [
        "kafka",
        "out"
      ],
      "to": [
        "saga",
        "in"
      ],
      "semantics": "async"
    },
    {
      "from": [
        "kafka",
        "out"
      ],
      "to": [
        "proj_read",
        "in"
      ],
      "semantics": "async"
    },
    {
      "from": [
        "kafka",
        "out"
      ],
      "to": [
        "proj_srch",
        "in"
      ],
      "semantics": "async"
    },
    {
      "from": [
        "kafka",
        "out"
      ],
      "to": [
        "proj_hot",
        "in"
      ],
      "semantics": "async"
    },
    {
      "from": [
        "kafka",
        "out"
      ],
      "to": [
        "notifier",
        "in"
      ],
      "semantics": "async"
    },
    {
      "from": [
        "kafka",
        "out"
      ],
      "to": [
        "analytics",
        "in"
      ],
      "semantics": "async"
    },
    {
      "from": [
        "saga",
        "db"
      ],
      "to": [
        "rds",
        "in"
      ],
      "semantics": "sync"
    },
    {
      "from": [
        "proj_read",
        "db"
      ],
      "to": [
        "rstore",
        "in"
      ],
      "semantics": "sync"
    },
    {
      "from": [
        "proj_srch",
        "out"
      ],
      "to": [
        "es",
        "in"
      ],
      "semantics": "sync"
    },
    {
      "from": [
        "proj_srch",
        "out"
      ],
      "to": [
        "dlq",
        "in"
      ],
      "semantics": "sync",
      "transform": {
        "kind": "prob",
        "value": 0.01
      }
    },
    {
      "from": [
        "proj_hot",
        "out"
      ],
      "to": [
        "redis",
        "in"
      ],
      "semantics": "sync"
    },
    {
      "from": [
        "analytics",
        "out"
      ],
      "to": [
        "s3_an",
        "in"
      ],
      "semantics": "sync"
    },
    {
      "from": [
        "cli_qry",
        "out"
      ],
      "to": [
        "cdn",
        "in"
      ],
      "semantics": "sync"
    },
    {
      "from": [
        "cdn",
        "out"
      ],
      "to": [
        "alb_r",
        "in"
      ],
      "semantics": "sync"
    },
    {
      "from": [
        "alb_r",
        "out"
      ],
      "to": [
        "query",
        "in"
      ],
      "semantics": "sync"
    },
    {
      "from": [
        "query",
        "out"
      ],
      "to": [
        "redis",
        "in"
      ],
      "semantics": "sync"
    },
    {
      "from": [
        "query",
        "db"
      ],
      "to": [
        "rstore",
        "in"
      ],
      "semantics": "sync",
      "transform": {
        "kind": "prob",
        "value": 0.2
      }
    }
