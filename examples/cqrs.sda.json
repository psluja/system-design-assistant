        }
      ],
      "relations": [
        {
          "key": "cost",
          "reads": [
            "throughput",
            "unitCost"
          ],
          "expr": "inflow(throughput) * self(unitCost)"
        },
        {
          "key": "overflow",
          "reads": [
            "throughput"
          ],
          "expr": "max(0, inflow(throughput) - self(throughput))"
        }
      ],
      "bands": [
        {
          "key": "overflow",
          "band": {
            "shape": "minTargetMax",
            "max": 0
          }
        }
