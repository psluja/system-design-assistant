  "descriptions": {
    "cli_cmd": "Web/mobile issuing writes (POST commands)",
    "cli_qry": "Web/mobile issuing reads (GET queries)",
    "waf": "Edge WAF for the write API",
    "alb_w": "Application load balancer, command path",
    "apigw": "REST command API, auth + throttling",
    "cmd": "Validates + dedups, writes source of truth, emits events",
    "rds": "Connection pooling for the write DB",
    "aurora": "Source of truth, strongly consistent",
    "kafka": "Ordered per-key event backbone, fan-out to projectors",
    "saga": "Consumes events, issues follow-up commands (acyclic: writes to source of truth)",
    "proj_read": "Builds the relational read model from events",
    "proj_srch": "Builds the search index from events",
    "proj_hot": "Maintains the hot cache projection from events",
    "rstore": "Relational read model for queries",
    "es": "Search projection",
    "redis": "Hot read projection / query cache",
    "dlq": "Dead-letter queue for failed search projection",
    "notifier": "Sends user notifications from events",
    "analytics": "Windowed aggregation of events",
    "s3_an": "Aggregated analytics output",
    "cdn": "Edge cache/TLS for the query API",
    "alb_r": "Application load balancer, query path",
    "query": "Serves reads: cache then read store on miss"
  },
